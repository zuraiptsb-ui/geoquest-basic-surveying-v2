rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isLecturer() {
      return request.auth != null && exists(/databases/$(database)/documents/lecturers/$(request.auth.uid));
    }

    function isAnonymousStudent() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == "anonymous";
    }

    function validScores(scores) {
      return scores is list
        && scores.size() == 5
        && scores[0] is number && scores[0] >= 0 && scores[0] <= 20
        && scores[1] is number && scores[1] >= 0 && scores[1] <= 20
        && scores[2] is number && scores[2] >= 0 && scores[2] <= 20
        && scores[3] is number && scores[3] >= 0 && scores[3] <= 20
        && scores[4] is number && scores[4] >= 0 && scores[4] <= 20;
    }

    function quizAttemptPath(attemptId) {
      return /databases/$(database)/documents/attempts/$(attemptId);
    }

    function matchingSubmittedAttempt(studentId) {
      return request.resource.data.lastAttemptId is string
        && getAfter(quizAttemptPath(request.resource.data.lastAttemptId)).data.studentId == studentId
        && getAfter(quizAttemptPath(request.resource.data.lastAttemptId)).data.submittedBy == request.auth.uid
        && getAfter(quizAttemptPath(request.resource.data.lastAttemptId)).data.topic == request.resource.data.lastSubmittedTopic;
    }

    function validAnonymousStudentScoreUpdate(studentId) {
      return isAnonymousStudent()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "scores", "total", "percentage", "badge", "topicBadges",
          "completionStatus", "lastAttemptId", "lastAttemptUid",
          "lastSubmittedTopic", "updatedAt"
        ])
        && request.resource.data.id == studentId
        && request.resource.data.name == resource.data.name
        && request.resource.data.className == resource.data.className
        && request.resource.data.lastAttemptUid == request.auth.uid
        && request.resource.data.lastSubmittedTopic is number
        && request.resource.data.lastSubmittedTopic >= 0
        && request.resource.data.lastSubmittedTopic < 5
        && validScores(request.resource.data.scores)
        && request.resource.data.total == request.resource.data.scores[0] + request.resource.data.scores[1] + request.resource.data.scores[2] + request.resource.data.scores[3] + request.resource.data.scores[4]
        && request.resource.data.percentage == request.resource.data.total
        && matchingSubmittedAttempt(studentId);
    }

    function validAnonymousAttemptCreate() {
      return isAnonymousStudent()
        && request.resource.data.submittedBy == request.auth.uid
        && request.resource.data.studentId is string
        && exists(/databases/$(database)/documents/students/$(request.resource.data.studentId))
        && request.resource.data.studentName == get(/databases/$(database)/documents/students/$(request.resource.data.studentId)).data.name
        && request.resource.data.topic is number
        && request.resource.data.topic >= 0
        && request.resource.data.topic < 5
        && request.resource.data.correct is number
        && request.resource.data.incorrect is number
        && request.resource.data.total is number
        && request.resource.data.correct >= 0
        && request.resource.data.incorrect >= 0
        && request.resource.data.total > 0
        && request.resource.data.correct + request.resource.data.incorrect == request.resource.data.total
        && request.resource.data.percentage is number
        && request.resource.data.percentage >= 0
        && request.resource.data.percentage <= 100;
    }

    match /lecturers/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Leaderboard information is public and updates in real time.
    match /students/{studentId} {
      allow read: if true;
      allow create, delete: if isLecturer();
      allow update: if isLecturer() || validAnonymousStudentScoreUpdate(studentId);
    }

    match /rankings/{studentId} {
      allow read: if true;
      allow write: if isLecturer()
        || (isAnonymousStudent()
          && request.resource.data.studentId == studentId
          && request.resource.data.lastAttemptUid == request.auth.uid
          && request.resource.data.lastAttemptId is string
          && getAfter(quizAttemptPath(request.resource.data.lastAttemptId)).data.studentId == studentId
          && getAfter(quizAttemptPath(request.resource.data.lastAttemptId)).data.submittedBy == request.auth.uid);
    }

    match /badges/{badgeId} {
      allow read: if true;
      allow write: if isLecturer();
    }

    match /quizzes/{questionId} {
      allow read: if true;
      allow write: if isLecturer();
    }

    match /attempts/{attemptId} {
      allow read: if isLecturer();
      allow create: if validAnonymousAttemptCreate() || isLecturer();
      allow update, delete: if isLecturer();
    }

    match /settings/{documentId} {
      allow read: if true;
      allow write: if isLecturer();
    }
  }
}
